# Neon Postgres connection string
# Get this from your Neon dashboard: https://console.neon.tech
# Use the "Pooled connection" string (includes -pooler in the host) for serverless/Next.js.
DATABASE_URL=""

# Better Auth (https://www.better-auth.com)
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=""
# Base URL of the app; used for auth callbacks/cookies.
BETTER_AUTH_URL="http://localhost:3000"
